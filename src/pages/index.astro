---
import '@/styles/global.css';
import { UploadDropzone } from '@/components/upload/UploadDropzone.tsx';

const title = 'Analiza tu Excel online — fórmulas, dependencias y Markdown para IA';
const description =
  'Sube un archivo de Excel (.xlsx, .xlsm) y descubre cómo está construido: fórmulas, celdas críticas, dependencias entre hojas y errores circulares. Además, exporta a Markdown listo para ChatGPT o Claude. Gratis y 100% privado: tu archivo nunca sale de tu navegador.';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebApplication',
        name: 'Analizador de Excel',
        applicationCategory: 'UtilitiesApplication',
        operatingSystem: 'Web',
        offers: { '@type': 'Offer', price: '0' },
        description,
      })}
    />
    <script is:inline>
      // Aplica el tema guardado (o el del sistema) antes del primer paint, sin destello.
      const raw = localStorage.getItem('excel2md-a11y-settings');
      const stored = raw ? JSON.parse(raw) : {};
      let theme = stored.theme;
      if (!theme && stored.darkMode === true) theme = 'dark';
      if (!theme && stored.darkMode === false) theme = 'light';
      if (!theme) theme = 'system';
      const dark =
        theme === 'dark' ||
        (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.classList.toggle('dark', dark);
    </script>
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased dark:bg-[#141517] dark:text-slate-100">
    <!-- Primera pantalla: la herramienta sobre un fondo de cuadrícula de hoja de cálculo -->
    <main
      id="subir"
      class="relative overflow-hidden bg-[linear-gradient(to_right,#10b98114_1px,transparent_1px),linear-gradient(to_bottom,#10b98114_1px,transparent_1px)] bg-[size:56px_28px]"
    >
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-emerald-50/70 via-transparent to-white dark:from-emerald-950/30 dark:to-[#141517]"></div>
      <div class="relative mx-auto flex min-h-[92vh] max-w-3xl flex-col justify-center px-4 py-12">
        <p class="mx-auto flex items-center gap-1.5 rounded-full border border-emerald-200 bg-white px-4 py-1.5 text-xs font-semibold text-[#0b5c30] shadow-sm dark:border-emerald-900 dark:bg-[#202124] dark:text-emerald-300">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          100% privado · sin registro · gratis
        </p>
        <h1 class="mt-6 text-center text-4xl font-extrabold tracking-tight sm:text-5xl">
          Sube tu Excel y descubre
          <span class="bg-gradient-to-r from-[#0b5c30] to-emerald-500 bg-clip-text text-transparent">
            cómo está construido
          </span>
        </h1>
        <p class="mx-auto mt-4 max-w-xl text-center text-lg text-slate-600 dark:text-slate-300">
          Tu hoja de cálculo, radiografiada: fórmulas, celdas críticas, dependencias entre hojas y
          versión en Markdown lista para tu IA. Todo en segundos.
        </p>
        <div class="mt-10">
          <UploadDropzone client:load />
        </div>
        <ul class="mt-8 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-slate-500 dark:text-slate-400">
          <li class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-amber-500" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Análisis instantáneo
          </li>
          <li class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-[#107c41]" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Tu archivo nunca sale de tu navegador
          </li>
          <li class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-sky-500" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Sin límites ni cuentas
          </li>
        </ul>
      </div>
    </main>

    <!-- Demo visual: así se ve el análisis -->
    <section class="border-t border-slate-100 bg-slate-50 dark:border-[#26282d] dark:bg-[#101113]">
      <div class="mx-auto max-w-5xl px-4 py-20">
        <h2 class="text-center text-3xl font-bold">Tu Excel, en lenguaje Excel</h2>
        <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600 dark:text-slate-300">
          Nada de listas técnicas: ves tu hoja tal cual, haces clic en una celda y la herramienta
          pinta de dónde sale su valor y quién lo usa — como "rastrear precedentes", pero sin abrir
          Excel.
        </p>

        <div class="mx-auto mt-10 max-w-2xl overflow-hidden rounded-xl border border-slate-200 border-t-4 border-t-[#107c41] bg-white shadow-xl">
          <div class="flex items-stretch border-b border-[#cfd4d0] bg-[#f4f8f5] text-sm">
            <div class="flex w-16 items-center justify-center border-r border-[#cfd4d0] bg-white px-2 py-1.5 font-mono font-bold text-[#0b5c30]">D4</div>
            <div class="flex items-center border-r border-[#cfd4d0] px-3 py-1.5 font-serif font-semibold italic text-[#107c41]">fx</div>
            <div class="flex flex-1 items-center bg-white px-3 py-1.5 font-mono text-slate-800">=D2+D3</div>
          </div>
          <table class="w-full border-separate border-spacing-0 text-sm">
            <thead>
              <tr class="text-xs font-semibold text-[#3e5747]">
                <th class="h-7 w-10 border border-[#cfd4d0] bg-[#edf2ee]"><span class="sr-only">Fila</span></th>
                <th class="h-7 border border-[#cfd4d0] bg-[#edf2ee] px-2">A</th>
                <th class="h-7 border border-[#cfd4d0] bg-[#edf2ee] px-2">B</th>
                <th class="h-7 border border-[#cfd4d0] bg-[#edf2ee] px-2">C</th>
                <th class="h-7 border border-[#cfd4d0] bg-[#107c41] px-2 text-white">D</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th class="h-7 border border-[#cfd4d0] bg-[#edf2ee] text-xs font-semibold text-[#3e5747]">1</th>
                <td class="border border-[#e3e5e8] px-2">Producto</td>
                <td class="border border-[#e3e5e8] px-2">Precio</td>
                <td class="border border-[#e3e5e8] px-2">Cantidad</td>
                <td class="border border-[#e3e5e8] px-2">Total</td>
              </tr>
              <tr>
                <th class="h-7 border border-[#cfd4d0] bg-[#edf2ee] text-xs font-semibold text-[#3e5747]">2</th>
                <td class="border border-[#e3e5e8] bg-[#f6f9f7] px-2">Manzanas</td>
                <td class="border border-[#e3e5e8] bg-[#f6f9f7] px-2 text-right">2.50</td>
                <td class="border border-[#e3e5e8] bg-[#f6f9f7] px-2 text-right">4</td>
                <td class="border border-[#e3e5e8] bg-[#cfe3f5] px-2 text-right">10.00</td>
              </tr>
              <tr>
                <th class="h-7 border border-[#cfd4d0] bg-[#edf2ee] text-xs font-semibold text-[#3e5747]">3</th>
                <td class="border border-[#e3e5e8] px-2">Peras</td>
                <td class="border border-[#e3e5e8] px-2 text-right">3.00</td>
                <td class="border border-[#e3e5e8] px-2 text-right">2</td>
                <td class="border border-[#e3e5e8] bg-[#cfe3f5] px-2 text-right">6.00</td>
              </tr>
              <tr>
                <th class="h-7 border border-[#cfd4d0] bg-[#edf2ee] text-xs font-semibold text-[#3e5747]">4</th>
                <td class="border border-[#e3e5e8] bg-[#f6f9f7] px-2"></td>
                <td class="border border-[#e3e5e8] bg-[#f6f9f7] px-2"></td>
                <td class="border border-[#e3e5e8] bg-[#f6f9f7] px-2 font-semibold">Suma</td>
                <td class="border-2 border-[#107c41] bg-white px-2 text-right font-bold">16.00</td>
              </tr>
            </tbody>
          </table>
          <div class="border-t border-[#cfd4d0] bg-[#f4f8f5] px-4 py-3">
            <div class="flex flex-wrap items-center gap-2 text-sm">
              <span class="rounded-md bg-[#107c41] px-2 py-0.5 font-mono text-xs font-bold text-white">Ventas!D4</span>
              <span class="flex items-center gap-1 text-xs font-semibold uppercase tracking-wide text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                Se calcula a partir de
              </span>
              <span class="rounded-md border border-[#9dc3e6] bg-[#cfe3f5] px-2 py-0.5 font-mono text-xs">D2</span>
              <span class="rounded-md border border-[#9dc3e6] bg-[#cfe3f5] px-2 py-0.5 font-mono text-xs">D3</span>
              <span class="flex items-center gap-1 text-xs font-semibold uppercase tracking-wide text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                Se usa en
              </span>
              <span class="rounded-md border border-[#e6c45c] bg-[#ffedb3] px-2 py-0.5 font-mono text-xs">Resumen!B2</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Qué obtienes -->
    <section class="bg-white dark:bg-[#141517]">
      <div class="mx-auto max-w-5xl px-4 py-20">
        <h2 class="text-center text-3xl font-bold">¿Qué obtienes al analizar tu Excel?</h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-3">
          <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg dark:border-[#2b2f37] dark:bg-[#202124]">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-100">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-[#0b5c30]" aria-hidden="true"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
            </div>
            <h3 class="mt-4 text-lg font-bold">Radiografía del libro</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
              Cuántas hojas, celdas y fórmulas tiene, qué celdas son críticas (las que más se usan
              en otros cálculos) y si existen dependencias circulares — el error silencioso más
              común en Excel.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg dark:border-[#2b2f37] dark:bg-[#202124]">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-100">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-sky-700" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            <h3 class="mt-4 text-lg font-bold">Rastreo de dependencias</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
              Haz clic en cualquier celda y ve resaltado de qué celdas depende y quién la usa,
              incluso entre hojas distintas. Ideal para auditar un archivo heredado antes de
              tocarlo.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg dark:border-[#2b2f37] dark:bg-[#202124]">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-violet-100">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-violet-700" aria-hidden="true"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
            </div>
            <h3 class="mt-4 text-lg font-bold">Markdown para tu IA</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
              Copia el contenido como Markdown con las fórmulas visibles, o como prompt listo para
              pegar en ChatGPT o Claude. La IA entiende el archivo de verdad, no solo los valores.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section class="border-t border-slate-100 bg-slate-50 dark:border-[#26282d] dark:bg-[#101113]">
      <div class="mx-auto max-w-5xl px-4 py-20">
        <h2 class="text-center text-3xl font-bold">Cómo funciona</h2>
        <ol class="mx-auto mt-10 grid max-w-4xl gap-10 sm:grid-cols-3">
          <li class="text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-[#107c41] text-lg font-bold text-white shadow-md">1</div>
            <h3 class="mt-4 font-bold">Arrastra tu archivo</h3>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Suelta tu .xlsx o .xlsm en el recuadro de arriba. No hace falta cuenta ni correo.
            </p>
          </li>
          <li class="text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-[#107c41] text-lg font-bold text-white shadow-md">2</div>
            <h3 class="mt-4 font-bold">Se analiza en tu navegador</h3>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              El archivo se procesa al instante con JavaScript local: nunca se sube a ningún
              servidor.
            </p>
          </li>
          <li class="text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-[#107c41] text-lg font-bold text-white shadow-md">3</div>
            <h3 class="mt-4 font-bold">Explora y comparte</h3>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Navega la hoja con dependencias resaltadas y copia el Markdown para documentar o
              consultar a una IA.
            </p>
          </li>
        </ol>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white dark:bg-[#141517]">
      <div class="mx-auto max-w-3xl px-4 py-20">
        <h2 class="text-center text-3xl font-bold">Preguntas frecuentes</h2>
        <div class="mt-8 space-y-3">
          <details class="group rounded-xl border border-slate-200 bg-white p-5 transition open:border-emerald-300 open:shadow-md dark:border-[#2b2f37] dark:bg-[#202124] dark:open:border-emerald-800">
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold [&::-webkit-details-marker]:hidden">
              ¿Mis datos se suben a algún servidor?
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0 text-[#107c41] transition group-open:rotate-45" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            </summary>
            <p class="mt-3 text-slate-600 dark:text-slate-300">
              No. Esta página es un sitio estático: el archivo se lee y se analiza con JavaScript
              en tu propio navegador. Puedes comprobarlo desconectando internet después de cargar
              la página — el análisis sigue funcionando.
            </p>
          </details>
          <details class="group rounded-xl border border-slate-200 bg-white p-5 transition open:border-emerald-300 open:shadow-md dark:border-[#2b2f37] dark:bg-[#202124] dark:open:border-emerald-800">
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold [&::-webkit-details-marker]:hidden">
              ¿Qué formatos acepta?
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0 text-[#107c41] transition group-open:rotate-45" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            </summary>
            <p class="mt-3 text-slate-600 dark:text-slate-300">
              Libros de Excel <code>.xlsx</code> y <code>.xlsm</code>, con una o varias hojas.
            </p>
          </details>
          <details class="group rounded-xl border border-slate-200 bg-white p-5 transition open:border-emerald-300 open:shadow-md dark:border-[#2b2f37] dark:bg-[#202124] dark:open:border-emerald-800">
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold [&::-webkit-details-marker]:hidden">
              ¿Para qué sirve pasar un Excel a Markdown?
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0 text-[#107c41] transition group-open:rotate-45" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            </summary>
            <p class="mt-3 text-slate-600 dark:text-slate-300">
              Para pegar tablas en documentación, wikis, GitHub o Notion; para versionar el
              contenido con Git; y sobre todo para dárselo a una IA de forma que entienda las
              fórmulas y relaciones entre celdas, no solo los resultados.
            </p>
          </details>
          <details class="group rounded-xl border border-slate-200 bg-white p-5 transition open:border-emerald-300 open:shadow-md dark:border-[#2b2f37] dark:bg-[#202124] dark:open:border-emerald-800">
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold [&::-webkit-details-marker]:hidden">
              ¿Qué es una dependencia circular y por qué importa?
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0 text-[#107c41] transition group-open:rotate-45" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            </summary>
            <p class="mt-3 text-slate-600 dark:text-slate-300">
              Es cuando una celda depende de otra que, directa o indirectamente, depende de la
              primera. Excel las resuelve con valores aproximados o errores, y suelen pasar
              desapercibidas. El análisis las detecta y te muestra la cadena exacta.
            </p>
          </details>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="bg-gradient-to-r from-[#0b5c30] to-[#1d9e5f]">
      <div class="mx-auto max-w-4xl px-4 py-16 text-center">
        <h2 class="text-3xl font-bold text-white">¿Listo para ver tu Excel por dentro?</h2>
        <p class="mt-3 text-emerald-100">
          Gratis, sin registro, y tu archivo nunca sale de tu computadora.
        </p>
        <a
          href="#subir"
          class="mt-6 inline-flex items-center gap-2 rounded-xl bg-white px-8 py-3.5 text-sm font-bold text-[#0b5c30] shadow-lg transition hover:bg-emerald-50"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M8 13h2"/><path d="M14 13h2"/><path d="M8 17h2"/><path d="M14 17h2"/></svg>
          Subir mi Excel
        </a>
      </div>
    </section>

    <footer class="border-t border-slate-100 bg-white dark:border-[#26282d] dark:bg-[#141517]">
      <p class="mx-auto max-w-4xl px-4 py-8 text-center text-sm text-slate-500 dark:text-slate-400">
        Hecho con
        <a class="font-semibold text-[#0b5c30] underline dark:text-emerald-400" href="https://github.com/skapxd/excel2md">@skapxd/excel2md</a>
        — código abierto en GitHub.
      </p>
    </footer>
  </body>
</html>
